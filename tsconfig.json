{
  "compileOnSave": false,
  "compilerOptions": {
      "declaration": true,
      "module": "node16",
      "moduleResolution": "node16",
      "target": "ES2020",
      "noImplicitAny": true,
      "sourceMap": false,
      "importHelpers": false,
      "inlineSourceMap": true,
      "inlineSources": true,
      "outDir": "dist",
      "rootDir": "src",
      "skipLibCheck": true,
      "sourceRoot": ".",
      "noUnusedLocals": true,
      "esModuleInterop": true
  }
}
